[
  {
    "$match": {
      "$expr": {
        "$and": [
          { "$eq": [ { "$type": "$estimated_start" }, "string" ] },
          { "$eq": [ { "$type": "$estimated_finish" }, "string" ] },
          { "$ne": [ "$estimated_start", "" ] },
          { "$ne": [ "$estimated_finish", "" ] },
          {
            "$lte": [
              { "$dateFromString": { "dateString": "$estimated_start", "onError": null, "onNull": null } },
              "$$NOW"
            ]
          },
          {
            "$gte": [
              { "$dateFromString": { "dateString": "$estimated_finish", "onError": null, "onNull": null } },
              "$$NOW"
            ]
          }
        ]
      }
    }
  },
  {
    "$group": {
      "_id": null,
      "tasksTotal": {
        "$sum": 1
      },
      "tasksWithEstimatedEffort": {
        "$sum": {
          "$cond": [
            {
              "$in": [
                { "$type": "$custom_attributes.Estimated Effort"},
                ["int", "long", "double"]
              ]
            },
            1,
            0
          ]
        }
      }
    }
  },
  {
    "$project": {
      "_id": 0,
      "tasksTotal": 1,
      "tasksWithEstimatedEffort": 1
    }
  }
]